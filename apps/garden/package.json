{
  "name": "garden",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3040",
    "build": "next build",
    "build:standalone:fix": "next build && mkdir -p .next/standalone/.next && node ./scripts/fix-standalone-bun.mjs",
    "build:opennext": "next build && node ./scripts/fix-standalone-bun.mjs && open-next build && node ./scripts/verify-server-bundle-resolve.mjs",
    "verify:server-bundle": "node ./scripts/verify-server-bundle-resolve.mjs",
    "build:opennext:verify": "next build && node ./scripts/fix-standalone-bun.mjs && open-next build && node ./scripts/verify-server-bundle-resolve.mjs",
    "start": "next start -p 3040",
    "lint": "next lint",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@next/env": "15.2.4",
    "@personal-os-web/portfolio-data": "workspace:*",
    "@personal-os-web/portfolio-types": "workspace:*",
    "@personal-os-web/ui": "workspace:*",
    "@swc/helpers": "0.5.15",
    "@tailwindcss/typography": "^0.5.19",
    "@xyflow/react": "^12.3.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.9.0",
    "marked": "^18.0.2",
    "next": "15.2.4",
    "openai": "^4.77.0",
    "pg": "^8.13.1",
    "pg-protocol": "^1.6.1",
    "pg-types": "^2.2.0",
    "pgpass": "^1.0.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "styled-jsx": "5.1.6",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "15.2.4",
    "open-next": "3.1.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
