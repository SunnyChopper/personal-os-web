{
  "name": "web",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite --mode dev",
    "build": "vite build",
    "lint": "node ../../node_modules/eslint/bin/eslint.js .",
    "lint:fix": "node ../../node_modules/eslint/bin/eslint.js . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "node ../../node_modules/typescript/bin/tsc --noEmit -p tsconfig.app.json",
    "test": "node ../../node_modules/vitest/vitest.mjs run",
    "test:watch": "node ../../node_modules/vitest/vitest.mjs",
    "test:coverage": "node ../../node_modules/vitest/vitest.mjs run --coverage",
    "test:e2e": "node ../../node_modules/@playwright/test/cli.js test",
    "test:e2e:ui": "node ../../node_modules/@playwright/test/cli.js test --ui",
    "analyze": "vite-bundle-visualizer",
    "check-type-coverage": "node ../../node_modules/tsx/dist/cli.mjs scripts/check-type-coverage.ts",
    "validate-architecture": "node ../../node_modules/tsx/dist/cli.mjs scripts/validate-architecture.ts",
    "check-patterns": "node ../../node_modules/tsx/dist/cli.mjs scripts/check-patterns.ts",
    "validate": "node ../../node_modules/tsx/dist/cli.mjs scripts/validate-all.ts",
    "validate:quick": "node ../../node_modules/tsx/dist/cli.mjs scripts/validate-all.ts --quick",
    "validate:full": "bun run validate && bun run test && bun run test:e2e",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@excalidraw/excalidraw": "^0.18.0",
    "@personal-os-web/portfolio-data": "workspace:*",
    "@personal-os-web/portfolio-types": "workspace:*",
    "@personal-os-web/ui": "workspace:*",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/query-async-storage-persister": "^5.95.2",
    "@tanstack/react-query": "^5.90.16",
    "@tanstack/react-query-persist-client": "^5.95.2",
    "@tanstack/react-virtual": "^3.13.18",
    "@types/prismjs": "^1.26.5",
    "@xyflow/react": "^12.10.2",
    "aws-amplify": "^6.15.9",
    "axios": "^1.13.2",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cron-parser": "^5.5.0",
    "cronstrue": "^3.14.0",
    "framer-motion": "^12.38.0",
    "idb-keyval": "^6.2.2",
    "katex": "^0.16.27",
    "lucide-react": "^1.9.0",
    "prismjs": "^1.30.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.11.0",
    "react18-json-view": "^0.2.10",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.4.0",
    "unified": "^11.0.5",
    "zod": "^4.3.5",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.48.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-unicorn": "^58.0.0",
    "globals": "^16.5.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.6",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "type-coverage": "^2.29.7",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.1.5"
  }
}
