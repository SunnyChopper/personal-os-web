# Copy to `.env.dev` for local dev. The dev script runs Vite with `--mode dev` so `.env.dev` / `.env.dev.local` are loaded (not `.env.development`).
# Local backend — or omit both API/WS lines: hosted dev API is https://dev-api.sunnysingh.tech when you set those URLs.
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/assistant/ws

# Hosted dev (optional explicit copy-paste; must use Cognito IDs from the same dev stack as this API)
# VITE_API_BASE_URL=https://dev-api.sunnysingh.tech
# VITE_WS_URL=wss://YOUR_API_ID.execute-api.us-east-1.amazonaws.com/dev

VITE_AWS_REGION=us-east-1
VITE_AWS_USER_POOL_ID=your_user_pool_id_here
VITE_AWS_USER_POOL_WEB_CLIENT_ID=your_web_client_id_here
VITE_AWS_IDENTITY_POOL_ID=your_identity_pool_id_here
