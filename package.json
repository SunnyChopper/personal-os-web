{
  "name": "personal-os-web-workspace",
  "private": true,
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build --concurrency=1",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e --filter=web",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare": "husky",
    "check:infra:frontend:dev": "node ../scripts/terraform-stack.mjs plan edge dev",
    "check:infra:frontend:prod": "node ../scripts/terraform-stack.mjs plan edge prod",
    "check:infra:backend:dev": "node ../scripts/terraform-stack.mjs plan api dev",
    "check:infra:backend:prod": "node ../scripts/terraform-stack.mjs plan api prod",
    "check:infra:dev": "node ../scripts/terraform-stack.mjs plan edge dev && node ../scripts/terraform-stack.mjs plan api dev",
    "check:infra:prod": "node ../scripts/terraform-stack.mjs plan edge prod && node ../scripts/terraform-stack.mjs plan api prod",
    "deploy:infra:frontend:dev": "node ../scripts/deploy-infra.mjs dev",
    "deploy:infra:frontend:prod": "node ../scripts/deploy-infra.mjs prod",
    "deploy:infra:backend:dev": "node ../scripts/terraform-stack.mjs apply api dev",
    "deploy:infra:backend:prod": "node ../scripts/terraform-stack.mjs apply api prod",
    "deploy:infra:dev": "node ../scripts/deploy-infra.mjs dev && node ../scripts/terraform-stack.mjs apply api dev",
    "deploy:infra:prod": "node ../scripts/deploy-infra.mjs prod && node ../scripts/terraform-stack.mjs apply api prod",
    "deploy:frontend:dev": "node ../scripts/run-wsl.mjs -- bun ../scripts/deploy-frontend.mjs dev all",
    "deploy:frontend:prod": "node ../scripts/run-wsl.mjs -- bun ../scripts/deploy-frontend.mjs prod all",
    "deploy:frontend:personal-os:dev": "node ../scripts/run-wsl.mjs -- bun ../scripts/deploy-frontend.mjs dev personal-os",
    "deploy:frontend:personal-os:prod": "node ../scripts/run-wsl.mjs -- bun ../scripts/deploy-frontend.mjs prod personal-os",
    "deploy:frontend:public-garden:dev": "node ../scripts/run-wsl.mjs -- bun ../scripts/deploy-frontend.mjs dev public-garden",
    "deploy:frontend:public-garden:prod": "node ../scripts/run-wsl.mjs -- bun ../scripts/deploy-frontend.mjs prod public-garden",
    "deploy:spa:dev": "node scripts/deploy-spa.mjs dev",
    "deploy:spa:prod": "node scripts/deploy-spa.mjs prod",
    "deploy:garden:dev": "node scripts/deploy-garden.mjs dev",
    "deploy:garden:prod": "node scripts/deploy-garden.mjs prod"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "~5.9.3"
  },
  "overrides": {
    "lru-cache": "10.4.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "patchedDependencies": {
    "open-next@3.1.3": "patches/open-next@3.1.3.patch"
  }
}
