# Copy to .env.deploy.dev or .env.deploy.prod (gitignored) for local deploy scripts.
# After `npm run deploy:infra:dev` (or prod) from monorepo root, these four are refreshed from Terraform output:
#   SPA_BUCKET, CLOUDFRONT_DISTRIBUTION_ID, GARDEN_ASSETS_BUCKET, GARDEN_LAMBDA_NAME

SPA_BUCKET=
CLOUDFRONT_DISTRIBUTION_ID=
GARDEN_ASSETS_BUCKET=
GARDEN_LAMBDA_NAME=

# Optional; default matches CI
AWS_REGION=us-east-1

# Build-time Vite: deploy scripts also load `apps/web/.env.dev` or `apps/web/.env.prod` (Cognito, API, WS).
# Override or add VITE_* here only if you need values different from those files; otherwise optional.
# VITE_API_BASE_URL=
# VITE_WS_URL=
# VITE_AWS_REGION=us-east-1
# VITE_AWS_USER_POOL_ID=
# VITE_AWS_USER_POOL_WEB_CLIENT_ID=
# VITE_AWS_IDENTITY_POOL_ID=

# Public garden (OpenNext) — required for `deploy:frontend:*` when including public-garden (mirror deploy-garden.yml / Terraform garden_lambda env)
# NEXT_PUBLIC_SITE_URL=https://dev.example.com
# PUBLIC_GARDEN_DATABASE_URL=
# PUBLIC_GARDEN_USER_ID=
# OPENAI_API_KEY=
